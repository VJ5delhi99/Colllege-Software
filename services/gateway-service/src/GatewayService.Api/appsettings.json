{
  "ConnectionStrings": {
    "mysql": "server=mysql;port=3306;database=gatewaydb;user=app;password=app123!",
    "redis": "redis:6379",
    "rabbitmq": "rabbitmq://guest:guest@rabbitmq:5672"
  },
  "Platform": {
    "Jwt": {
      "Authority": "https://identity.university360.local",
      "Audience": "university360-api",
      "SigningKey": "development-signing-key-please-change"
    },
    "ObjectStorage": {
      "Provider": "MinIO",
      "PublicBaseUrl": "http://minio:9000",
      "SigningKey": "development-object-storage-signing-key"
    }
  },
  "DownstreamServices": {
    "Identity": "http://identity-service:8080",
    "Academic": "http://academic-service:8080",
    "Attendance": "http://attendance-service:8080",
    "Communication": "http://communication-service:8080",
    "Finance": "http://finance-service:8080"
  },
  "ReverseProxy": {
    "Routes": {
      "attendance-v1": {
        "ClusterId": "attendance",
        "Match": {
          "Path": "/api/v1/attendance/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/{**catch-all}" }
        ]
      },
      "results-v1": {
        "ClusterId": "results",
        "Match": {
          "Path": "/api/v1/results/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/results/{**catch-all}" }
        ]
      },
      "payments-v2": {
        "ClusterId": "payments",
        "Match": {
          "Path": "/api/v2/payments/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/{**catch-all}" }
        ]
      },
      "announcements-v1": {
        "ClusterId": "communication",
        "Match": {
          "Path": "/api/v1/announcements/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "attendance": {
        "Destinations": {
          "d1": {
            "Address": "http://attendance-service:8080/"
          }
        }
      },
      "results": {
        "Destinations": {
          "d1": {
            "Address": "http://exam-service:8080/"
          }
        }
      },
      "payments": {
        "Destinations": {
          "d1": {
            "Address": "http://finance-service:8080/"
          }
        }
      },
      "communication": {
        "Destinations": {
          "d1": {
            "Address": "http://communication-service:8080/"
          }
        }
      }
    }
  }
}
